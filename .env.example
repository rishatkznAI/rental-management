# Production frontend API base URL. This must point to the Railway backend API,
# not to the GitHub Pages frontend URL.
VITE_API_URL=https://your-backend.up.railway.app

# Optional production login link to a separate demo frontend deployment.
# Leave empty or unset to hide the "Открыть демо-режим" link.
VITE_DEMO_URL=

# Demo frontend only:
# VITE_API_URL=https://your-demo-backend.up.railway.app
# VITE_DEMO_MODE=true

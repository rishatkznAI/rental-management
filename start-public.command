#!/bin/bash
# start-public.command
# Двойной клик — запускает приложение и открывает доступ из интернета
# Работает через Cloudflare Tunnel (бесплатно, без регистрации)
# -----------------------------------------------------------------------
cd "$(dirname "$0")"

echo ""
echo "╔════════════════════════════════════════════════════════╗"
echo "║   Запуск приложения с доступом из интернета            ║"
echo "║   Работает пока этот терминал открыт                  ║"
echo "╚════════════════════════════════════════════════════════╝"

# ── Всегда пересобираем свежую версию ───────────────────────────────────
echo ""
echo "🔨 Собираем актуальную версию приложения..."
npm run build
if [ $? -ne 0 ]; then
  echo "❌ Сборка не удалась."
  read -p "Нажмите Enter для выхода..."
  exit 1
fi

# ── Запускаем статический сервер на порту 4173 ───────────────────────────
echo ""
echo "🖥  Запускаем локальный сервер (порт 4173)..."
npx --yes serve -s dist -p 4173 --no-clipboard > /tmp/serve_log.txt 2>&1 &
SERVE_PID=$!

# Ждём пока сервер поднимется
sleep 3

# Проверяем что сервер запустился
if ! kill -0 $SERVE_PID 2>/dev/null; then
  echo "❌ Сервер не запустился."
  read -p "Нажмите Enter для выхода..."
  exit 1
fi

# ── Открываем туннель через Cloudflare ───────────────────────────────────
echo "✅ Сервер запущен"
echo ""
echo "🌐 Создаём публичный адрес..."
echo "   ┌─────────────────────────────────────────────────────────┐"
echo "   │  Ждите — через ~10 сек появится ссылка вида:           │"
echo "   │  https://xxxx-xxxx-xxxx.trycloudflare.com              │"
echo "   │                                                         │"
echo "   │  Скопируйте её и отправьте сотрудникам.                │"
echo "   │  Работает пока окно открыто.                           │"
echo "   └─────────────────────────────────────────────────────────┘"
echo ""

# Запускаем Cloudflare Quick Tunnel (без аккаунта)
npx --yes cloudflared tunnel --url http://localhost:4173

# ── Завершение ───────────────────────────────────────────────────────────
kill $SERVE_PID 2>/dev/null
echo ""
echo "Сервер остановлен."
read -p "Нажмите Enter для выхода..."

# ══════════════════════════════════════════════════════
#  Конфигурация сервера
#  Скопируйте этот файл в .env и заполните значения
# ══════════════════════════════════════════════════════

# Порт сервера (по умолчанию 3000)
PORT=3000

# Токен бота из MAX Developer Portal (dev.max.ru)
# Получить: dev.max.ru → Чат-боты → Ваш бот → Токен
BOT_TOKEN=

# Отдельный токен бота менеджеров аренды (если используете отдельный MAX-бот)
MANAGER_BOT_TOKEN=

# Отдельный токен доставочного бота (если используете второй MAX-бот)
DELIVERY_BOT_TOKEN=

# Публичный URL для webhook или внешнего доступа к серверу
# Пример для Railway:
# WEBHOOK_URL=https://your-service.up.railway.app
WEBHOOK_URL=

# Отдельный публичный URL для доставочного webhook (необязательно).
# Если не указан, будет использован WEBHOOK_URL.
DELIVERY_WEBHOOK_URL=

# Отдельный публичный URL для webhook бота менеджеров (необязательно).
# Если не указан, будет использован WEBHOOK_URL.
MANAGER_WEBHOOK_URL=
